{
  "entities": {
    "VideoPost": {
      "title": "Video Post",
      "description": "A video entry for shorts or youtube",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the video" },
        "description": { "type": "string", "description": "Description of the video" },
        "category": { "type": "string", "description": "Category of the video" },
        "thumbnail_url": { "type": "string", "format": "uri", "description": "URL of the thumbnail image" },
        "video_url": { "type": "string", "format": "uri", "description": "URL of the video file (for shorts)" },
        "youtube_url": { "type": "string", "format": "uri", "description": "URL of the youtube video" },
        "status": { "type": "string", "enum": ["Review Pending", "Submitted"], "description": "Approval status" },
        "author_uid": { "type": "string", "description": "UID of the manager who uploaded" },
        "author_name": { "type": "string", "description": "Name of the manager who uploaded" },
        "created_at": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["title", "category", "status", "author_uid", "created_at"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information",
      "type": "object",
      "properties": {
        "display_name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photo_url": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["admin", "manager", "user"] },
        "is_admin": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["display_name", "email", "role"]
    },
    "AppSettings": {
      "title": "App Settings",
      "description": "Global configuration and secrets",
      "type": "object",
      "properties": {
        "maintenance_mode": { "type": "boolean" },
        "app_version": { "type": "string" },
        "welcome_message": { "type": "string" },
        "r2_access_key_id": { "type": "string" },
        "r2_secret_access_key": { "type": "string" },
        "r2_endpoint": { "type": "string" },
        "r2_bucket": { "type": "string" },
        "r2_directory": { "type": "string" },
        "r2_public_url": { "type": "string" },
        "quick_links": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "emoji": { "type": "string" },
              "title": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        }
      }
    },
    "ActivityLog": {
      "title": "Activity Log",
      "description": "Record of administrative actions",
      "type": "object",
      "properties": {
        "action": { "type": "string", "description": "Description of the action performed" },
        "user_id": { "type": "string" },
        "user_name": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["upload", "approve", "settings", "user_management"] }
      },
      "required": ["action", "user_id", "timestamp", "type"]
    }
  },
  "firestore": {
    "/shorts_videos/{videoId}": {
      "schema": "VideoPost",
      "description": "Collection of shorts videos"
    },
    "/kids_youtube_videos/{videoId}": {
      "schema": "VideoPost",
      "description": "Collection of kids youtube videos"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/app_settings/{configId}": {
      "schema": "AppSettings",
      "description": "Global app configuration"
    },
    "/activity_logs/{logId}": {
      "schema": "ActivityLog",
      "description": "Administrative activity history"
    }
  }
}
