rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ৭. Activity Logs (Moved to top for priority)
    match /activity_logs/{logId} {
      allow read: if isAuthenticated() && (request.auth.token.email == "shomedesk@gmail.com" || isAdmin());
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ===============================================================
    // ১. হেল্পার ফাংশন (আপনার লজিক এবং সিকিউরিটির জন্য)
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // অ্যাডমিন চেক (আপনার অরিজিনাল is_admin ফিল্ড এবং আপনার ইমেইল অনুযায়ী)
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "shomedesk@gmail.com" || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('is_admin', false) == true ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin');
    }

    // ম্যানেজার চেক (যাতে তারা ভিডিও আপলোড করতে পারে)
    function isManager() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager';
    }

    // ===============================================================
    // ২. কালেকশন রুলস (আপনার ৬টি পয়েন্ট হুবহু আলাদা করে দেওয়া হলো)
    // ===============================================================

    // ১. Shorts Videos
    match /shorts_videos/{document} {
      allow read: if true; 
      allow write: if isAuthenticated(); 
    }

    // ২. Kids YouTube Videos
    match /kids_youtube_videos/{document} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // ৩. App Settings
    match /app_settings/{document} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // ৪. Subscription Offers
    match /subscription_offers/{offerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ৫. Users
    match /users/{document} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ৬. Video Comments
    match /video_comments/{document} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // ৭. Activity Logs
    match /activity_logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
  }
}
