rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ৭. Activity Logs (Moved to top for priority)
    match /activity_logs/{logId} {
      allow read: if isAuthenticated() && (request.auth.token.email == "shomedesk@gmail.com" || isAdmin());
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ===============================================================
    // ১. হেল্পার ফাংশন (আপনার লজিক এবং সিকিউরিটির জন্য)
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // অ্যাডমিন চেক (আপনার অরিজিনাল is_admin ফিল্ড এবং আপনার ইমেইল অনুযায়ী)
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "shomedesk@gmail.com" || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('is_admin', false) == true ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin');
    }

    // ম্যানেজার চেক (যাতে তারা ভিডিও আপলোড করতে পারে)
    function isManager() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager';
    }

    // ===============================================================
    // ২. কালেকশন রুলস (আপনার ৬টি পয়েন্ট হুবহু আলাদা করে দেওয়া হলো)
    // ===============================================================

    // ১. Shorts Videos (বাচ্চারা দেখতে পারবে, অ্যাডমিন/ম্যানেজার আপলোড করবে)
    match /shorts_videos/{document} {
      allow read: if true; 
      allow write: if isAuthenticated(); 
      allow create, delete: if isAdmin() || isManager(); 
    }

    // ২. Kids YouTube Videos
    match /kids_youtube_videos/{document} {
      allow read: if true;
      allow create, write, delete: if isAdmin() || isManager();
    }

    // ৩. App Settings
    match /app_settings/{document} {
      allow read: if true; 
      allow create, write, delete: if isAdmin();
    }

    // ৪. Subscription Offers
    match /subscription_offers/{offerId} {
      allow read: if true;
      allow create, write, delete: if isAdmin();
    }

    // ৫. Users (নিজের ডেটা নিজে, বাকি সব অ্যাডমিন)
    match /users/{document} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == document;
      allow write: if isAuthenticated() && (request.auth.uid == document || isAdmin());
      allow delete: if isAdmin();
    }

    // ৬. Video Comments
    match /video_comments/{document} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow write, delete: if isAdmin();
    }

    // ===============================================================
    // ৩. ফ্লাটারফ্লো এবং ডিফল্ট রুলস
    // ===============================================================

    // ফ্লাটারফ্লোর ডিফল্ট ইঞ্জিন রুলস (আপনার রিকোয়েস্ট অনুযায়ী)
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.token.email.matches("firebase@flutterflow.io");
    }

    // বাকি সব রাস্তা ব্লক (Hackers Blocked)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
